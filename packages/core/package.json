{
  "name": "ai-armor",
  "type": "module",
  "version": "0.1.3",
  "description": "Production AI toolkit for TypeScript -- rate limiting, cost tracking, fallback, caching, safety",
  "author": "billymaulana",
  "license": "MIT",
  "homepage": "https://github.com/billymaulana/ai-armor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/billymaulana/ai-armor",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/billymaulana/ai-armor/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "rate-limiting",
    "cost-tracking",
    "fallback",
    "caching",
    "safety",
    "guardrails",
    "production",
    "typescript",
    "openai",
    "anthropic",
    "gemini",
    "ai-sdk",
    "middleware"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./ai-sdk": {
      "import": {
        "types": "./dist/ai-sdk.d.ts",
        "default": "./dist/ai-sdk.js"
      },
      "require": {
        "types": "./dist/ai-sdk.d.cts",
        "default": "./dist/ai-sdk.cjs"
      }
    },
    "./http": {
      "import": {
        "types": "./dist/http.d.ts",
        "default": "./dist/http.js"
      },
      "require": {
        "types": "./dist/http.d.cts",
        "default": "./dist/http.cjs"
      }
    },
    "./redis": {
      "import": {
        "types": "./dist/redis.d.ts",
        "default": "./dist/redis.js"
      },
      "require": {
        "types": "./dist/redis.d.cts",
        "default": "./dist/redis.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && node scripts/fix-dts.mjs",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "@ai-sdk/openai": ">=3.0.0",
    "ai": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "dependencies": {
    "gpt-tokenizer": "^2.8.1"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "ai": "^6.0.0"
  }
}
