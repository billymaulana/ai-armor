{
  "name": "@ai-armor/nuxt",
  "type": "module",
  "version": "0.1.2",
  "description": "Nuxt module for ai-armor -- production AI toolkit with rate limiting, cost tracking, fallback, caching, and safety guardrails for Nuxt 3/4",
  "author": "billymaulana",
  "license": "MIT",
  "homepage": "https://github.com/billymaulana/ai-armor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/billymaulana/ai-armor",
    "directory": "packages/nuxt"
  },
  "bugs": {
    "url": "https://github.com/billymaulana/ai-armor/issues"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "ai",
    "llm",
    "rate-limiting",
    "cost-tracking",
    "safety",
    "guardrails",
    "ai-armor"
  ],
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "prepack": "nuxt-module-build build"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0"
  },
  "dependencies": {
    "@nuxt/kit": "^3.16.0 || ^4.0.0",
    "@nuxt/schema": "^3.16.0 || ^4.0.0",
    "ai-armor": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/test-utils": "^3.17.2",
    "nuxt": "^4.4.2",
    "vue": "^3.5.0"
  }
}
