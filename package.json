{
  "name": "ai-armor-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm -r --parallel --filter './packages/*' run dev",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "docs:dev": "pnpm --filter docs run dev",
    "docs:build": "pnpm --filter docs run build",
    "playground:core": "tsx playground/basic.ts",
    "playground:nuxt": "pnpm --filter playground-nuxt run dev",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "quality": "pnpm lint && pnpm typecheck && vitest run"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "tsdown": "^0.12.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4"
    }
  }
}
